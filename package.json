{
  "name": "@botamation/ui",
  "version": "1.0.0",
  "description": "Botamation shared React UI component library",
  "type": "module",
  "main": "./dist/botamation-ui.umd.cjs",
  "module": "./dist/botamation-ui.js",
  "exports": {
    ".": {
      "import": "./dist/botamation-ui.js",
      "require": "./dist/botamation-ui.umd.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "@headlessui/react": ">=2.0.0",
    "framer-motion": ">=10.0.0",
    "clsx": ">=2.0.0"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "@headlessui/react": "^2.1.2",
    "framer-motion": "^11.3.28",
    "clsx": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.4.0"
  }
}
